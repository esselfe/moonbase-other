          MODULE=ffmpeg
         VERSION=8.1
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=https://www.ffmpeg.org/releases
      SOURCE_VFY=sha256:b072aed6871998cce9b36e7774033105ca29e33632be5b6347f3206898e0756a
        WEB_SITE=https://www.ffmpeg.org/
         ENTERED=20020327
